{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spotiamp+",
  "version": "0.6.9",
  "identifier": "app.spotiamp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBQkJDREQyNUUyN0EwRjcKUldUM29DZGUwczI3MmtHNUkzMXNVdVMwL2VmczR0ei9BSU9SNjllbHQzUUxaQmdnTjlQSDIvUlcK",
      "endpoints": [
        "https://github.com/fdeox/spotiamp-plus/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp"
      }
    },
    "macOS": {}
  }
}